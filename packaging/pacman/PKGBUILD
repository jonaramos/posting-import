# Maintainer: Your Name <your.email@example.com>
# Contributor: Your Name <your.email@example.com>

pkgname=posting-importer
pkgver=0.1.0
pkgrel=1
pkgdesc="Import API collections from Postman, Insomnia, and Bruno to Posting TUI format"
arch=('x86_64' 'aarch64')
url="https://github.com/yourusername/posting-importer"
license=('MIT' 'Apache-2.0')
makedepends=('cargo')
provides=("${pkgname}")
conflicts=("${pkgname}")
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/yourusername/posting-importer/archive/v${pkgver}.tar.gz")
sha256sums=('REPLACE_WITH_ACTUAL_SHA256')

prepare() {
  cd "${pkgname}-${pkgver}"
  cargo fetch --locked
}

build() {
  cd "${pkgname}-${pkgver}"
  cargo build --release --locked
}

check() {
  cd "${pkgname}-${pkgver}"
  cargo test --release --locked
}

package() {
  cd "${pkgname}-${pkgver}"

  install -Dm755 "target/release/posting-importer" "${pkgdir}/usr/bin/posting-importer"

  # Install shell completions
  install -Dm644 "completions/posting-importer.bash" "${pkgdir}/usr/share/bash-completion/completions/posting-importer"
  install -Dm644 "completions/posting-importer.fish" "${pkgdir}/usr/share/fish/vendor_completions.d/posting-importer.fish"
  install -Dm644 "completions/_posting-importer" "${pkgdir}/usr/share/zsh/site-functions/_posting-importer"

  # Install man page
  install -Dm644 "man/posting-importer.1" "${pkgdir}/usr/share/man/man1/posting-importer.1"

  # Install documentation
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
